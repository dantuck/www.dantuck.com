---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.svelte';
import Footer from '../components/Footer.svelte';
import Tags from '../components/Tags.astro';
import FeedbackLink from '../components/FeedbackLink.astro';
import JsonLd from '../components/JsonLd.astro';

const { frontmatter } = Astro.props;
const { ingredients, title, description, prepTime, cookTime, tags, publishDate, image } = frontmatter;
const permalink = frontmatter.permalink ?? Astro.url.href;

const isDraft = frontmatter.draft === true;
const isFuture = publishDate && new Date(publishDate) > new Date();
const showDevBanner = import.meta.env.DEV && (isDraft || isFuture);
const devBannerLabel = isDraft ? 'DRAFT' : `SCHEDULED · publishes ${publishDate}`;
const isoDate = publishDate ? new Date(publishDate).toISOString().slice(0, 10) : undefined;

const pathname = Astro.url.pathname.replace(/\/$/, '');
const ogImage = new URL(`/og${pathname}.png`, Astro.site).toString();

// Convert "15 min" / "2 hr" style strings to ISO 8601 duration (PT15M / PT2H)
function toIsoDuration(value: string | undefined): string | undefined {
  if (!value) return undefined;
  const minMatch = value.match(/^(\d+)\s*min/i);
  if (minMatch) return `PT${minMatch[1]}M`;
  const hrMatch = value.match(/^(\d+)\s*h/i);
  if (hrMatch) return `PT${hrMatch[1]}H`;
  return undefined;
}

const recipeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: title,
  description,
  datePublished: publishDate ? new Date(publishDate).toISOString() : undefined,
  prepTime: toIsoDuration(prepTime),
  cookTime: toIsoDuration(cookTime),
  recipeIngredient: ingredients ?? [],
  url: permalink,
  author: {
    '@type': 'Person',
    name: 'Daniel Tucker',
    url: 'https://www.dantuck.com/',
  },
};
---

<html lang={frontmatter.lang || 'en'}>
  <head>
    <BaseHead {title} {description} {permalink} image={ogImage} type="article" />
    <JsonLd schema={recipeSchema} />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    {showDevBanner && (
      <div class="dev-banner">{devBannerLabel}</div>
    )}
    <Header client:load path={Astro.url.pathname} />

    <article data-pagefind-body>
      <main class="max-content pt-4 pb-12">

        <h1 class="text-center pb-4 text-primary">{title}</h1>

        <div class="recipe-meta">
          {prepTime && <span class="meta-pill">Prep: {prepTime}</span>}
          {cookTime && <span class="meta-pill">Cook: {cookTime}</span>}
          {publishDate && <time datetime={isoDate} class="meta-date">{publishDate}</time>}
        </div>

        <div class:list={['recipe-body', !ingredients?.length && 'no-ingredients']}>
          {ingredients?.length > 0 && (
            <aside class="ingredients-col">
              <h2 class="col-label">Ingredients</h2>
              <ul data-ingredients>
                {ingredients.map((i: string) => (
                  <li><Fragment set:html={i} /></li>
                ))}
              </ul>
            </aside>
          )}
          <div class="instructions-col">
            <h2 class="col-label">Methods</h2>
            <slot />
          </div>
        </div>

        {tags?.length > 0 && (
          <div data-pagefind-meta="tags">
            <Tags {tags} />
          </div>
        )}
        <FeedbackLink />

      </main>
    </article>

    <Footer client:load transition:persist />
  </body>
</html>

<style>
  .recipe-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }

  .meta-pill {
    background: #1a2230;
    border: 1px solid rgba(255, 140, 0, 0.3);
    color: rgb(255, 140, 0);
    font-size: 0.82rem;
    padding: 0.2rem 0.75rem;
    border-radius: 3px;
  }

  .meta-date {
    color: rgba(170, 170, 170, 0.5);
    font-size: 0.78rem;
    margin-left: auto;
  }

  .recipe-body {
    display: grid;
    grid-template-columns: 38fr 62fr;
    gap: 2.5rem;
    align-items: start;
  }

  .recipe-body.no-ingredients {
    grid-template-columns: 1fr;
  }

  .ingredients-col {
    position: sticky;
    top: 1.5rem;
  }

  .col-label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: rgba(170, 170, 170, 0.5);
    margin: 0 0 0.75rem;
    font-weight: 400;
  }

  [data-ingredients] {
    list-style: disc;
    padding-left: 1.25rem;
    margin: 0;
    line-height: 1.9;
    font-size: 0.9rem;
  }

  .instructions-col {
    min-width: 0;
  }

  @media (max-width: 700px) {
    .recipe-body {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .ingredients-col {
      position: static;
    }
  }

  .dev-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9999;
    background: #7c2d12;
    color: #fed7aa;
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    padding: 0.35rem 1rem;
  }
</style>
