---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.svelte';
import Footer from '../components/Footer.svelte';

const { frontmatter = {}, ...rest } = Astro.props;
const title = frontmatter.title ?? rest.title;
const description = frontmatter.description ?? rest.description;
const permalink = frontmatter.permalink ?? rest.permalink ?? Astro.url.href;
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} type="website" image="https://www.dantuck.com/og/default.png" />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header client:load path={Astro.url.pathname} {title} />
    <article class="max-content py-6">
      <slot />
    </article>
    <Footer client:load transition:persist />
  </body>
</html>
