---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.svelte';
import Footer from '../components/Footer.svelte';

const { frontmatter } = Astro.props;
const { title, description } = frontmatter;
const permalink = frontmatter.permalink ?? Astro.url.href;
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} type="website" image="https://www.dantuck.com/og/default.png" />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header client:only="svelte" {title} />
    <article class="max-content py-6">
      <slot />
    </article>
    <Footer client:load />
  </body>
</html>
