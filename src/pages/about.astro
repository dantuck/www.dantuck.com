---
import AboutLayout from "../layouts/About.astro";
import aboutData from "../data/about.json";

const { intro, now, previously, military, education, skills } = aboutData;
---

<AboutLayout
  description="Daniel Tucker — Senior Staff Software Engineer in Colorado. Writing about software, tools, and systems."
>
  <p>{intro}</p>

  <h3 class="about-section-title">Now</h3>

  <div class="about-timeline about-timeline--now">
    {now.map((entry) => (
      <div class="about-entry">
        <span class="about-dot" style={`background: ${entry.dotColor};`}></span>
        <p class="about-company">
          {entry.companyUrl ? <a href={entry.companyUrl}>{entry.company}</a> : entry.company}
        </p>
        <p class="about-location">{entry.location}</p>
        {entry.roles.map((role, i) => (
          <div class={`about-role ${i > 0 ? 'about-role--prev' : ''}`}>
            <span class={`about-role-title ${role.current ? 'about-role-title--current' : ''}`}>
              {role.title}
            </span>
            {role.dates && <span class="about-meta">{role.dates}</span>}
            <p>{role.description}</p>
          </div>
        ))}
      </div>
    ))}
  </div>

  <h3 class="about-section-title">Previously</h3>

  <div class="about-timeline about-timeline--prev">
    {previously.map((entry) => (
      <div class="about-entry">
        <span class="about-dot" style={`background: rgba(255, 140, 0, ${entry.dotOpacity});`}></span>
        <span class="about-meta">{entry.dates}</span>
        <p class="about-company">
          {entry.companyUrl ? <a href={entry.companyUrl}>{entry.company}</a> : entry.company}
        </p>
        <p class="about-location">{entry.location}</p>
        {entry.roles.map((role, i) => (
          <div class={`about-role ${i > 0 ? 'about-role--prev' : ''}`}>
            <span class="about-role-title">{role.title}</span>
            {role.dates && <span class="about-meta">{role.dates}</span>}
            <p>{role.description}</p>
          </div>
        ))}
      </div>
    ))}
  </div>

  <div class="about-footer">
    <div class="about-footer-col">
      <h3 class="about-section-title">Military</h3>
      <p class="about-company">{military.organization}</p>
      <div class="about-role">
        <span class="about-role-title">{military.role}</span>
        <span class="about-meta">{military.dates}</span>
      </div>
    </div>
    <div class="about-footer-col">
      <h3 class="about-section-title">Education</h3>
      <p class="about-company">{education.institution}</p>
      <div class="about-role">
        <span class="about-role-title">{education.degree}</span>
        <span class="about-meta">{education.year}</span>
      </div>
    </div>
  </div>

  <h3 class="about-section-title">Skills & Interests</h3>
  <ul>
    {skills.map((skill) => (
      <li>{skill}</li>
    ))}
  </ul>
</AboutLayout>

<style>
  /* ── Section titles ─────────────────────────────────────────────────────── */

  .about-section-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    border-bottom: 1px solid rgba(255, 140, 0, 0.35);
    padding-bottom: 0.3rem;
    margin-top: 2rem;
    margin-bottom: 1.25rem;
    font-weight: 700;
  }

  /* ── Timeline container ─────────────────────────────────────────────────── */

  .about-timeline {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .about-timeline--now {
    border-left: 2px solid rgba(255, 140, 0, 0.5);
  }

  .about-timeline--prev {
    border-left: 2px solid rgba(255, 140, 0, 0.2);
  }

  /* ── Entry ──────────────────────────────────────────────────────────────── */

  .about-entry {
    position: relative;
    margin-bottom: 2rem;
  }

  .about-entry:last-child {
    margin-bottom: 0;
  }

  .about-dot {
    position: absolute;
    left: -1.85rem;
    top: 0.35rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Company / location ─────────────────────────────────────────────────── */

  .about-company {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-strong);
    margin: 0 0 0.1rem;
  }

  .about-company a {
    color: var(--color-text-strong);
  }

  .about-company a:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .about-location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0 0 0.6rem;
  }

  /* ── Role blocks ────────────────────────────────────────────────────────── */

  .about-role {
    margin-bottom: 0.75rem;
  }

  .about-role--prev {
    border-top: 1px solid rgba(255, 140, 0, 0.1);
    padding-top: 0.75rem;
  }

  .about-role p {
    margin: 0.25rem 0 0;
    color: var(--color-text);
    line-height: 1.6;
  }

  .about-role-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-strong);
  }

  .about-role-title--current {
    color: var(--color-accent);
  }

  /* ── Meta (dates) ───────────────────────────────────────────────────────── */

  .about-meta {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.3rem;
  }

  /* ── Footer row (Military + Education) ─────────────────────────────────── */

  .about-footer {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .about-footer-col {
    flex: 1;
    min-width: 200px;
  }

  .about-footer-col .about-section-title {
    margin-top: 1.5rem;
  }
</style>
