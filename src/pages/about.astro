---
import { Image } from "astro:assets";
import AboutLayout from "../layouts/About.astro";
import { parseAboutContent } from "../lib/aboutContent";
import aboutRaw from "../data/about.md?raw";
import headshot from "../images/about/headshot.webp";

const { title, description, intro, now, previously, military, education, skills } = parseAboutContent(aboutRaw);
---

<AboutLayout title={title} description={description}>
  <div class="about-intro">
    <Image
      src={headshot}
      alt="Portrait of Daniel Tucker"
      class="about-photo"
      widths={[200, 400]}
      sizes="140px"
    />

    {intro.map((paragraph) => (
      <p>{paragraph}</p>
    ))}
  </div>

  <h2 class="about-section-title">Now</h2>

  <div class="about-timeline about-timeline--now">
    {now.map((entry) => (
      <div class="about-entry">
        <span class="about-dot about-dot--solid" style={`background: ${entry.dotColor}; border-color: ${entry.dotColor};`}></span>
        <p class="about-company">
          {entry.companyUrl ? <a href={entry.companyUrl}>{entry.company}</a> : entry.company}
        </p>
        <p class="about-location">{entry.location}</p>
        {entry.roles.map((role, i) => (
          <div class={`about-role ${i > 0 ? 'about-role--prev' : ''}`}>
            <span class={`about-role-title ${role.current ? 'about-role-title--current' : ''}`}>
              {role.title}
            </span>
            {role.dates && <span class="about-meta">{role.dates}</span>}
            <p>{role.description}</p>
          </div>
        ))}
      </div>
    ))}
  </div>

  <h2 class="about-section-title">Previously</h2>

  <div class="about-timeline about-timeline--prev">
    {previously.map((entry) => (
      <div class="about-entry">
        <span class="about-dot about-dot--hollow" style={`border-color: rgba(255, 140, 0, ${entry.dotOpacity});`}></span>
        <span class="about-meta">{entry.dates}</span>
        <p class="about-company">
          {entry.companyUrl ? <a href={entry.companyUrl}>{entry.company}</a> : entry.company}
        </p>
        <p class="about-location">{entry.location}</p>
        {entry.roles.map((role, i) => (
          <div class={`about-role ${i > 0 ? 'about-role--prev' : ''}`}>
            <span class="about-role-title">{role.title}</span>
            {role.dates && <span class="about-meta">{role.dates}</span>}
            <p>{role.description}</p>
          </div>
        ))}
      </div>
    ))}
  </div>

  <div class="about-footer">
    <div class="about-footer-col">
      <h2 class="about-section-title">Military</h2>
      <p class="about-company">{military.organization}</p>
      <div class="about-role">
        <span class="about-role-title">{military.role}</span>
        <span class="about-meta">{military.dates}</span>
      </div>
    </div>
    <div class="about-footer-col">
      <h2 class="about-section-title">Education</h2>
      <p class="about-company">{education.institution}</p>
      <div class="about-role">
        <span class="about-role-title">{education.degree}</span>
        <span class="about-meta">{education.year}</span>
      </div>
    </div>
  </div>

  <h2 class="about-section-title">Skills & Interests</h2>
  <ul>
    {skills.map((skill) => (
      <li>{skill}</li>
    ))}
  </ul>
</AboutLayout>

<style>
  /* ── Photo ──────────────────────────────────────────────────────────────── */

  .about-intro {
    margin-bottom: 1rem;
  }

  .about-intro::after {
    content: "";
    display: table;
    clear: both;
  }

  .about-photo {
    float: left;
    width: 140px;
    height: 140px;
    border-radius: 12px;
    object-fit: cover;
    margin: 0 1.75rem 1rem 0;
    shape-outside: margin-box;
  }

  .about-intro p:first-child {
    margin-top: 0;
  }

  @media (max-width: 600px) {
    .about-photo {
      float: none;
      display: block;
      margin: 0 auto 1.25rem;
    }
  }

  /* ── Section titles ─────────────────────────────────────────────────────── */

  .about-section-title {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent-text);
    border-bottom: 1px solid rgba(255, 140, 0, 0.35);
    padding-bottom: 0.3rem;
    margin-top: 2rem;
    margin-bottom: 1.25rem;
    font-weight: 700;
  }

  /* ── Timeline container ─────────────────────────────────────────────────── */

  .about-timeline {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .about-timeline--now {
    border-left: 1px solid var(--color-border);
  }

  .about-timeline--prev {
    border-left: 1px solid var(--color-border);
  }

  /* ── Entry ──────────────────────────────────────────────────────────────── */

  .about-entry {
    position: relative;
    margin-bottom: 2rem;
  }

  .about-entry:last-child {
    margin-bottom: 0;
  }

  .about-dot {
    position: absolute;
    left: calc(-1.5rem - 6.5px);
    top: calc(0.35rem - 1.5px);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid transparent;
    background: transparent;
    box-sizing: border-box;
    flex-shrink: 0;
  }

  .about-dot--solid {
    border-width: 0;
  }

  .about-dot--hollow {
    background: var(--color-bg);
  }

  /* ── Company / location ─────────────────────────────────────────────────── */

  .about-company {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-strong);
    margin: 0 0 0.1rem;
  }

  .about-company a {
    color: var(--color-text-strong);
  }

  .about-company a:hover {
    color: var(--color-accent-text);
    text-decoration: none;
  }

  .about-location {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0 0 0.6rem;
  }

  /* ── Role blocks ────────────────────────────────────────────────────────── */

  .about-role {
    margin-bottom: 0.75rem;
  }

  .about-role--prev {
    border-top: 1px solid rgba(255, 140, 0, 0.1);
    padding-top: 0.75rem;
  }

  .about-role p {
    margin: 0.25rem 0 0;
    color: var(--color-text);
    line-height: 1.6;
  }

  .about-role-title {
    display: block;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-strong);
  }

  .about-role-title--current {
    color: var(--color-accent-text);
  }

  /* ── Meta (dates) ───────────────────────────────────────────────────────── */

  .about-meta {
    display: block;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.3rem;
  }

  /* ── Footer row (Military + Education) ─────────────────────────────────── */

  .about-footer {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .about-footer-col {
    flex: 1;
    min-width: 200px;
  }

  .about-footer-col .about-section-title {
    margin-top: 1.5rem;
  }
</style>
