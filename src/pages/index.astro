---
import Header from '../components/Header.astro';
import BlogPostPreview from '../components/BlogPostPreview.astro';
import RecipePreview from '../components/RecipePreview.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.svelte';

const title = 'bytes of thought by Daniel Tucker';
const description = 'bytes of thought by Daniel Tucker.';
const permalink = 'https://www.dantuck.com/';

const allArticles = Object.values(import.meta.glob('./article/**/*.{md,mdx}', { eager: true }));
const allRecipes = Object.values(import.meta.glob('./recipe/**/*.{md,mdx}', { eager: true }));
let all = allArticles.concat(allRecipes).filter((post: any) => !post.frontmatter.draft);
all = all.sort((a: any, b: any) => new Date(b.frontmatter.publishDate).valueOf() - new Date(a.frontmatter.publishDate).valueOf());
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header />
    <main class="max-content pt-6">
      {all.map((p: any) => p.frontmatter.prepTime || p.frontmatter.cookTime
        ? <RecipePreview post={p} />
        : <BlogPostPreview post={p} />
      )}
    </main>
    <Footer client:load />
  </body>
</html>
