---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.svelte';
import Footer from '../../components/Footer.svelte';
import PortfolioCard from '../../components/PortfolioCard.astro';

const title = 'Portfolio — Daniel Tucker';
const description = 'A selection of sites and apps I have designed and built.';
const permalink = 'https://www.dantuck.com/portfolio/';

const allModules = Object.entries(
  import.meta.glob('../../data/portfolio/*.md', { eager: true }) as Record<string, any>
);

const projects = allModules
  .filter(([, mod]) => !mod.frontmatter.draft)
  .sort(([, a], [, b]) => {
    if (!!b.frontmatter.featured !== !!a.frontmatter.featured) {
      return b.frontmatter.featured ? 1 : -1;
    }
    return (a.frontmatter.sortOrder ?? 99) - (b.frontmatter.sortOrder ?? 99);
  })
  .map(([path, mod]) => ({
    slug: path.split('/').pop()!.replace('.md', ''),
    title: mod.frontmatter.title,
    tagline: mod.frontmatter.tagline,
    url: mod.frontmatter.url,
    screenshot: mod.frontmatter.screenshot,
    techStack: mod.frontmatter.techStack,
    label: mod.frontmatter.label,
  }));
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} />
  </head>
  <body>
    <div class="portfolio-bg">
      <div class="bg-blob b1"></div>
      <div class="bg-blob b2"></div>
      <div class="bg-blob b3"></div>
      <div class="bg-dots"></div>
      <div class="bg-noise"></div>
    </div>
    <Header client:load path={Astro.url.pathname} title="Portfolio" />
    <main id="main-content" class="max-content pt-6 pb-12">
      <div class="portfolio-list">
        {projects.map((project) => (
          <PortfolioCard {project} />
        ))}
        <a href="mailto:info@dantuck.com" class="contact-card">
          <span class="contact-eyebrow">Have a project in mind?</span>
          <strong class="contact-heading">Let's work<br />together.</strong>
          <span class="contact-cta">info@dantuck.com →</span>
        </a>
      </div>
    </main>
    <Footer client:load transition:persist />
  </body>
</html>

<style>
  .portfolio-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(130px);
  }

  .b1 {
    width: 700px;
    height: 700px;
    background: rgba(30, 40, 60, 0.8);
    top: -200px;
    left: -150px;
    opacity: 0.7;
  }

  .b2 {
    width: 400px;
    height: 400px;
    background: rgba(255, 140, 0, 0.08);
    bottom: -100px;
    right: 50px;
  }

  .b3 {
    width: 250px;
    height: 250px;
    background: rgba(255, 140, 0, 0.05);
    top: 40%;
    left: 50%;
  }

  .bg-dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(255, 140, 0, 0.1) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 90% 80% at 50% 50%, black 40%, transparent 100%);
  }

  .bg-noise {
    position: absolute;
    inset: 0;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 160px 160px;
  }

  .max-content {
    position: relative;
    z-index: 1;
  }

  .portfolio-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem 2.5rem;
    min-height: 160px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-raised);
    text-decoration: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .contact-card:hover {
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .contact-eyebrow {
    color: var(--color-text-muted);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: Consolas, Monaco, 'Andale Mono', 'Ubuntu Mono', monospace;
  }

  .contact-heading {
    font-family: "Fraunces Variable", Georgia, Cambria, "Times New Roman", serif;
    color: var(--color-accent-text);
    font-size: 1.6rem;
    line-height: 1.15;
    font-weight: 700;
  }

  .contact-cta {
    color: var(--color-text-muted);
    font-size: 0.78rem;
    margin-top: 0.25rem;
  }
</style>
