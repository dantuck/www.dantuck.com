---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.svelte';
import Footer from '../../components/Footer.svelte';
import PortfolioCard from '../../components/PortfolioCard.astro';
import PortfolioDrawer from '../../components/PortfolioDrawer.svelte';

const title = 'Portfolio — Daniel Tucker';
const description = 'A selection of sites and apps I have designed and built.';
const permalink = 'https://www.dantuck.com/portfolio/';

const allProjects = Object.values(
  import.meta.glob('../../data/portfolio/*.md', { eager: true }) as Record<string, any>
);

let featuredCount = 0;
const projects = allProjects
  .filter((p) => !p.frontmatter.draft)
  .sort((a, b) => {
    if (!!b.frontmatter.featured !== !!a.frontmatter.featured) {
      return b.frontmatter.featured ? 1 : -1;
    }
    return (a.frontmatter.sortOrder ?? 99) - (b.frontmatter.sortOrder ?? 99);
  })
  .map((p) => ({
    ...p.frontmatter,
    bodyHtml: p.compiledContent(),
    layoutSide: p.frontmatter.featured
      ? (['left', 'right'] as const)[featuredCount++] ?? 'right'
      : undefined,
  }));
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header client:load path={Astro.url.pathname} title="Portfolio" />
    <main class="max-content pt-6 pb-12">
      <div class="portfolio-grid">
        {projects.map((project) => (
          <PortfolioCard {project} />
        ))}
        <a href="mailto:info@dantuck.com" class="contact-card">
          <span class="contact-eyebrow">Have a project in mind?</span>
          <strong class="contact-heading">Let's work<br />together.</strong>
          <span class="contact-cta">info@dantuck.com →</span>
        </a>
      </div>
    </main>
    <Footer client:load transition:persist />
    <PortfolioDrawer client:only="svelte" />
  </body>
</html>

<script>
  document.querySelectorAll<HTMLElement>('.portfolio-card').forEach((card) => {
    const project = JSON.parse(card.dataset.project!);
    const bodyTemplate = card.querySelector('.card-body-html') as HTMLTemplateElement | null;
    project.bodyHtml = bodyTemplate?.innerHTML ?? '';

    const trigger = () => {
      document.dispatchEvent(
        new CustomEvent('open-portfolio-drawer', { detail: project })
      );
    };
    card.addEventListener('click', trigger);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        trigger();
      }
    });
  });
</script>

<style>
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 240px;
    grid-auto-flow: dense;
    gap: 0.75rem;
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.5rem;
    border-radius: 6px;
    border: 1px solid rgba(255, 140, 0, 0.2);
    background: linear-gradient(135deg, #1a2230 0%, #111820 100%);
    text-decoration: none;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .contact-card:hover {
    border-color: rgba(255, 140, 0, 0.6);
    background: linear-gradient(135deg, #1e2a3a 0%, #151e2a 100%);
  }

  .contact-eyebrow {
    color: rgba(180, 190, 200, 0.6);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .contact-heading {
    color: rgb(255, 140, 0);
    font-size: 1.6rem;
    line-height: 1.15;
    font-weight: 700;
  }

  .contact-cta {
    color: rgba(180, 190, 200, 0.8);
    font-size: 0.78rem;
    margin-top: 0.25rem;
  }

  @media (max-width: 599px) {
    .portfolio-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }

    .contact-card {
      min-height: 160px;
    }
  }
</style>
