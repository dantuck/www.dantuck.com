---
import Header from '../../components/Header.astro';
import BaseHead from '../../components/BaseHead.astro';
import BlogPostPreview from '../../components/BlogPostPreview.astro';
import Footer from '../../components/Footer.svelte';

export async function getStaticPaths() {
  const allArticles = Object.values(import.meta.glob('../article/*/*.md', { eager: true }));
  const allRecipes = Object.values(import.meta.glob('../recipe/*/*.md', { eager: true }));
  const allPosts = allArticles.concat(allRecipes).filter((post: any) => !post.frontmatter.draft);
  const allTagsUnique = [...new Set(allPosts.flatMap((p: any) => p.frontmatter.tags))];
  return allTagsUnique.map((tag) => ({ params: { tag }, props: { allPosts } }));
}

const { allPosts } = Astro.props;
const tag = Astro.params.tag;
const title = `Tagged "${tag}"`;
const description = 'bytes of thought by Daniel Tucker.';
const permalink = new URL(Astro.url.pathname, Astro.site).toString();

const articles = (allPosts as any[])
  .filter((post) => post.frontmatter.tags?.includes(tag))
  .sort((a, b) => new Date(b.frontmatter.publishDate).valueOf() - new Date(a.frontmatter.publishDate).valueOf());
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header {title} />
    <main class="max-content pt-6">
      {articles.map((p) => <BlogPostPreview post={p} />)}
      <p class="mt-6 text-sm">See <a href="/tags/">all tags</a>.</p>
    </main>
    <Footer client:load />
  </body>
</html>
