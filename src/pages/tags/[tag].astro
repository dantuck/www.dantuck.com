---
import Header from '../../components/Header.svelte';
import BaseHead from '../../components/BaseHead.astro';
import BlogPostPreview from '../../components/BlogPostPreview.astro';
import RecipePreview from '../../components/RecipePreview.astro';
import Footer from '../../components/Footer.svelte';

export async function getStaticPaths() {
  const allArticles = Object.values(import.meta.glob('../article/**/*.{md,mdx}', { eager: true }));
  const allRecipes = Object.values(import.meta.glob('../recipe/**/*.{md,mdx}', { eager: true }));
  const allPosts = allArticles.concat(allRecipes).filter((post: any) => {
    if (import.meta.env.DEV) return true;
    if (post.frontmatter.draft) return false;
    return new Date(post.frontmatter.publishDate) <= new Date();
  });
  const allTagsUnique = [...new Set(allPosts.flatMap((p: any) => p.frontmatter.tags ?? []))].filter(Boolean);
  return allTagsUnique.map((tag) => ({ params: { tag }, props: { allPosts } }));
}

const { allPosts } = Astro.props;
const tag = Astro.params.tag;
const title = `Tagged "${tag}"`;
const description = 'bytes of thought by Daniel Tucker.';
const permalink = new URL(Astro.url.pathname, Astro.site).toString();

const sorted = (allPosts as any[])
  .filter((post) => post.frontmatter.tags?.includes(tag))
  .sort((a, b) => new Date(b.frontmatter.publishDate).valueOf() - new Date(a.frontmatter.publishDate).valueOf());

const isSingleFeatured = sorted.length === 1 && sorted[0].frontmatter.featured;
const showHero = sorted.length > 1 || isSingleFeatured;
const [first, ...rest] = sorted;
const hero = showHero ? first : null;
const gridPosts = showHero ? rest : sorted;
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header client:load path={Astro.url.pathname} {title} />
    <main class="max-content pt-6 pb-12">
      {hero && ((hero as any).url?.startsWith('/recipe/')
        ? <RecipePreview post={hero} hero={true} />
        : <BlogPostPreview post={hero} hero={true} />
      )}
      <div class="post-grid">
        {gridPosts.map((p: any) => p.url?.startsWith('/recipe/')
          ? <RecipePreview post={p} />
          : <BlogPostPreview post={p} />
        )}
        {(gridPosts.length === 0 || sorted.length === 1) && (
          <div class="placeholder-card">
            <p class="placeholder-title">More coming soon</p>
            <p class="placeholder-body">Check back for more posts tagged "{tag}".</p>
          </div>
        )}
      </div>
      <p class="mt-6 text-sm">See <a href="/tags/">all tags</a>.</p>
    </main>
    <Footer client:load transition:persist />
  </body>
</html>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 639px) {
    .post-grid {
      grid-template-columns: 1fr;
    }
  }

  .placeholder-card {
    background: var(--color-bg-raised);
    border-radius: 6px;
    border: 1px solid var(--color-border);
    padding: 1.5rem 1.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .placeholder-title {
    font-size: 1rem;
    font-style: italic;
    color: var(--color-text-muted);
    margin: 0 0 0.25rem;
  }

  .placeholder-body {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
