---
import Header from '../components/Header.svelte';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.svelte';

const title = 'Page not found — bytes of thought';
const description = 'This page could not be found.';
const permalink = 'https://www.dantuck.com/404/';
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} type="website" image="https://www.dantuck.com/og/default.png" />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header client:load path={Astro.url.pathname} />
    <main id="main-content" class="max-content pt-6 pb-12">
      <section class="not-found">
        <p class="kicker">404</p>
        <h1 class="not-found-headline font-serif text-primary">
          Page not found<span class="text-orange-text">.</span>
        </h1>
        <p class="not-found-subhead text-site-text-muted">
          The page you're looking for doesn't exist, or may have moved.
        </p>
        <div class="not-found-ctas">
          <a href="/" class="hero-cta hero-cta-filled">Back home</a>
          <a href="/article" class="hero-cta hero-cta-ghost">Read the articles</a>
        </div>
      </section>
    </main>
    <Footer client:load transition:persist />
  </body>
</html>

<style>
  .not-found {
    padding: 2.5rem 0;
    text-align: center;
  }

  .not-found-headline {
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 1rem 0 1rem;
  }

  @media (min-width: 640px) {
    .not-found-headline { font-size: 3.75rem; }
  }

  .not-found-subhead {
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 32rem;
    margin: 0 auto 1.75rem;
  }

  .not-found-ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .hero-cta {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.65rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
  }

  .hero-cta-filled {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .hero-cta-filled:hover {
    text-decoration: none;
    opacity: 0.85;
  }

  .hero-cta-ghost {
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .hero-cta-ghost:hover {
    text-decoration: none;
    border-color: var(--color-accent);
    color: var(--color-accent-text);
  }
</style>
