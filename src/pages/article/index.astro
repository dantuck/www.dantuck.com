---
import Header from '../../components/Header.astro';
import BlogPostPreview from '../../components/BlogPostPreview.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.svelte';

const title = 'Articles';
const description = 'bytes of thought by Daniel Tucker.';
const permalink = new URL(Astro.url.pathname, Astro.site).toString();

let allArticles = Object.values(import.meta.glob('./**/*.{md,mdx}', { eager: true }));
allArticles = allArticles
  .filter((post: any) => !post.frontmatter.draft)
  .sort((a: any, b: any) => new Date(b.frontmatter.publishDate).valueOf() - new Date(a.frontmatter.publishDate).valueOf());
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header {title} />
    <main class="max-content pt-6">
      {allArticles.map((p: any) => <BlogPostPreview post={p} />)}
    </main>
    <Footer client:load />
  </body>
</html>
