---
import Header from '../../components/Header.svelte';
import PostPreview from '../../components/PostPreview.astro';
import PostListItem from '../../components/PostListItem.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.svelte';

const title = 'Articles';
const description = 'bytes of thought by Daniel Tucker.';
const permalink = new URL(Astro.url.pathname, Astro.site).toString();

const allArticles = (Object.values(import.meta.glob('./**/*.{md,mdx}', { eager: true })) as any[])
  .filter((post: any) => {
    if (import.meta.env.DEV) return true;
    if (!post.frontmatter.title) return false;
    if (post.frontmatter.draft) return false;
    return new Date(post.frontmatter.publishDate) <= new Date();
  })
  .sort((a, b) => new Date(b.frontmatter.publishDate).valueOf() - new Date(a.frontmatter.publishDate).valueOf());

const heroIndex = allArticles.findIndex((post: any) => post.frontmatter.featured);
const hero = heroIndex >= 0 ? allArticles[heroIndex] : allArticles[0];
const rest = allArticles.filter((post: any) => post !== hero);
---

<html lang="en">
  <head>
    <BaseHead {title} {description} {permalink} />
  </head>
  <body class="bg-site-bg text-site-text font-sans">
    <Header client:load path={Astro.url.pathname} {title} />
    <main class="max-content pt-6 pb-12">
      {hero && <PostPreview post={hero} hero={true} />}
      {rest.length > 0 && (
        <div class="post-list">
          {rest.map((p: any) => <PostListItem post={p} />)}
        </div>
      )}
    </main>
    <Footer client:load transition:persist />
  </body>
</html>

<style>
  .post-list {
    display: flex;
    flex-direction: column;
  }
</style>
