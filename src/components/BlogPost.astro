---
import Tags from './Tags.astro';
import FeedbackLink from './FeedbackLink.astro';

export interface Props {
  tags?: string[];
}
const { tags } = Astro.props;
---

<div class="prose">
  <slot />
  {tags?.length > 0 && (
    <div data-pagefind-meta="tags">
      <Tags {tags} />
    </div>
  )}
  <FeedbackLink />
</div>
