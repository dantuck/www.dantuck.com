---
import Tags from './Tags.astro';

export interface Props {
  post: any;
}
const { post } = Astro.props;
const { publishDate, title, prepTime, cookTime, tags, description } = post.frontmatter;
---

<article class="py-6 border-b border-site-text/15">
  <h2 class="m-0 mb-[0.2rem] text-[1.1rem]">
    <a href={post.url} class="text-primary no-underline hover:text-orange">{title}</a>
  </h2>
  <div class="flex flex-wrap gap-4 items-baseline mb-[0.35rem]">
    {prepTime && <span class="text-[0.8em] text-orange">Prep: {prepTime}</span>}
    {cookTime && <span class="text-[0.8em] text-orange">Cook: {cookTime}</span>}
    <time datetime={publishDate} class="text-[0.8em] text-site-text/60 ml-auto">{publishDate}</time>
  </div>
  {description && <p class="text-site-text text-[0.9em] leading-[1.6] m-0 mb-[0.35rem]">{description}</p>}
  {tags?.length > 0 && <Tags {tags} />}
</article>
