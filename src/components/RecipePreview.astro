---
export interface Props {
  post: any;
}
const { post } = Astro.props;
const { publishDate, title, prepTime, cookTime, tags, description } = post.frontmatter;
---

<article class="recipe-preview">
  <h2><a href={post.url}>{title}</a></h2>
  <div class="recipe-preview-meta">
    {prepTime && <span class="recipe-time">Prep: {prepTime}</span>}
    {cookTime && <span class="recipe-time">Cook: {cookTime}</span>}
    <time datetime={publishDate}>{publishDate}</time>
  </div>
  {description && <p class="recipe-preview-description">{description}</p>}
  {tags?.length > 0 && (
    <ul class="recipe-preview-tags">
      {tags.map((tag: string) => (
        <li><a href={`/tags/${tag}`}>#{tag}</a></li>
      ))}
    </ul>
  )}
</article>

<style>
  .recipe-preview {
    padding: 1.5rem 0;
    border-bottom: 1px solid rgba(170, 170, 170, 0.15);
  }

  .recipe-preview h2 {
    margin: 0 0 0.2rem;
    font-size: 1.1rem;
  }

  .recipe-preview h2 a {
    color: rgb(241, 241, 241);
    text-decoration: none;
  }

  .recipe-preview h2 a:hover {
    color: rgb(255, 140, 0);
  }

  .recipe-preview-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: baseline;
    margin-bottom: 0.35rem;
  }

  .recipe-preview-meta time {
    font-size: 0.8em;
    color: rgba(170, 170, 170, 0.6);
    margin-left: auto;
  }

  .recipe-time {
    font-size: 0.8em;
    color: rgb(255, 140, 0);
  }

  .recipe-preview-description {
    font-size: 0.9em;
    color: rgb(170, 170, 170);
    line-height: 1.6;
    margin: 0 0 0.35rem;
  }

  .recipe-preview-tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .recipe-preview-tags li a {
    font-size: 0.75em;
    color: rgba(170, 170, 170, 0.6);
    text-decoration: none;
  }

  .recipe-preview-tags li a:hover {
    color: rgb(255, 140, 0);
  }
</style>
