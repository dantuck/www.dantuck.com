---
import Tags from './Tags.astro';

export interface Props {
  post: any;
}
const { post } = Astro.props;
const { publishDate, title, description, tags, prepTime, cookTime } = post.frontmatter;
const isoDate = publishDate ? new Date(publishDate).toISOString().slice(0, 10) : undefined;
---

<div class="post-row">
  <a href={post.url} class="post-row-link">
    <div class="post-row-main">
      <h2 class="post-row-title text-primary">{title}</h2>
      {description && <p class="post-row-description text-site-text-muted">{description}</p>}
      {(prepTime || cookTime) && (
        <div class="post-row-meta">
          {prepTime && <span class="pill time-pill">Prep: {prepTime}</span>}
          {cookTime && <span class="pill time-pill">Cook: {cookTime}</span>}
        </div>
      )}
    </div>
    <time datetime={isoDate} class="post-row-date text-site-text-muted">{publishDate}</time>
  </a>
  {tags?.length > 0 && <Tags {tags} />}
</div>

<style>
  .post-row {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-row-link {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    text-decoration: none;
  }

  .post-row-link:hover .post-row-title {
    color: var(--color-accent);
  }

  .post-row-main {
    min-width: 0;
  }

  .post-row-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    transition: color 0.15s ease;
  }

  .post-row-description {
    font-size: 0.82rem;
    line-height: 1.5;
    margin: 0.2rem 0 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .post-row-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0.3rem 0 0;
  }

  .time-pill {
    color: var(--color-accent);
  }

  .post-row-date {
    flex: none;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  @media (max-width: 639px) {
    .post-row-link {
      flex-direction: column;
      gap: 0.3rem;
    }

    .post-row-description {
      white-space: normal;
    }
  }
</style>
