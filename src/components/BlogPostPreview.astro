---
import Tags from './Tags.astro';

export interface Props {
  post: any;
  hero?: boolean;
}
const { post, hero = false } = Astro.props;
const { publishDate, title, description, tags } = post.frontmatter;
---

{hero ? (
  <a href={post.url} class="hero-card">
    <h2 class="hero-title">{title}</h2>
    <time datetime={publishDate} class="hero-date">{publishDate}</time>
    {description && <p class="hero-description">{description}</p>}
    {tags?.length > 0 && <Tags {tags} />}
  </a>
) : (
  <a href={post.url} class="post-card">
    <h2 class="card-title">{title}</h2>
    <time datetime={publishDate} class="card-date">{publishDate}</time>
    {description && <p class="card-description">{description}</p>}
    {tags?.length > 0 && <Tags {tags} />}
  </a>
)}

<style>
  .hero-card {
    display: block;
    text-decoration: none;
    background: #1a2230;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-left: 4px solid rgb(255, 140, 0);
    padding: 1.5rem 1.75rem;
    transition: border-color 0.15s ease;
    margin-bottom: 0.75rem;
  }

  .hero-card:hover {
    border-color: rgba(255, 140, 0, 0.4);
  }

  .hero-title {
    color: rgb(241, 241, 241);
    font-size: 1.6rem;
    line-height: 1.25;
    margin: 0 0 0.5rem;
  }

  .hero-date {
    display: block;
    color: rgba(170, 170, 170, 0.6);
    font-size: 0.78rem;
    margin-bottom: 0.75rem;
  }

  .hero-description {
    color: rgb(170, 170, 170);
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
    background: #1a2230;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1.1rem 1.25rem;
    transition: border-color 0.15s ease;
  }

  .post-card:hover {
    border-color: rgba(255, 140, 0, 0.5);
  }

  .card-title {
    color: rgb(241, 241, 241);
    font-size: 1rem;
    line-height: 1.3;
    margin: 0 0 0.25rem;
  }

  .card-date {
    display: block;
    color: rgba(170, 170, 170, 0.6);
    font-size: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .card-description {
    color: rgb(170, 170, 170);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
