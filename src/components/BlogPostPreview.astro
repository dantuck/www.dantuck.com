---
import Tags from './Tags.astro';

export interface Props {
  post: any;
  hero?: boolean;
}
const { post, hero = false } = Astro.props;
const { publishDate, title, description, tags } = post.frontmatter;
const isoDate = publishDate ? new Date(publishDate).toISOString().slice(0, 10) : undefined;
---

{hero ? (
  <div class="hero-card">
    <a href={post.url} class="card-link">
      <h2 class="hero-title text-primary">{title}</h2>
      <time datetime={isoDate} class="hero-date text-site-text/60">{publishDate}</time>
      {description && <p class="hero-description text-site-text">{description}</p>}
    </a>
    {tags?.length > 0 && <Tags {tags} />}
  </div>
) : (
  <div class="post-card">
    <a href={post.url} class="card-link">
      <h2 class="card-title text-primary">{title}</h2>
      <time datetime={isoDate} class="card-date text-site-text/60">{publishDate}</time>
      {description && <p class="card-description text-site-text">{description}</p>}
    </a>
    {tags?.length > 0 && <Tags {tags} />}
  </div>
)}

<style>
  .hero-card {
    background: var(--color-bg-raised);
    border-radius: 6px;
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-accent);
    padding: 2rem 2.25rem;
    transition: border-color 0.15s ease;
    margin-bottom: 1.5rem;
  }

  .hero-card:hover {
    border-color: var(--color-accent);
  }

  .card-link {
    display: block;
    text-decoration: none;
  }

  .hero-title {
    font-family: "Fraunces Variable", Georgia, Cambria, "Times New Roman", serif;
    font-weight: 700;
    font-size: 1.8rem;
    line-height: 1.2;
    margin: 0 0 0.6rem;
  }

  .hero-date {
    display: block;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
  }

  .hero-description {
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 0.75rem;
  }

  .post-card {
    background: var(--color-bg-raised);
    border-radius: 6px;
    border: 1px solid var(--color-border);
    padding: 1.5rem 1.75rem;
    transition: border-color 0.15s ease;
  }

  .post-card:hover {
    border-color: var(--color-accent);
  }

  .card-title {
    font-size: 1rem;
    line-height: 1.3;
    margin: 0 0 0.25rem;
  }

  .card-date {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }

  .card-description {
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0 0 0.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
