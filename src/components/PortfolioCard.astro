---
import PortfolioBrowserFrame from './PortfolioBrowserFrame.astro';

export interface Props {
  project: {
    title: string;
    tagline: string;
    url: string;
    screenshot: string;
    techStack: string[];
    label?: string;
    slug: string;
  };
}

const { project } = Astro.props;
const label = project.label ?? 'Project';
---

<a href={`/portfolio/${project.slug}`} class="portfolio-card">
  <div class="card-left">
    <div class="card-label">
      <span class="label-line"></span>
      {label.toUpperCase()}
    </div>
    <strong class="card-title">{project.title}</strong>
    <span class="card-tagline">{project.tagline}</span>
    <div class="card-pills">
      {project.techStack.map((tech) => (
        <span class="pill">{tech}</span>
      ))}
    </div>
    <span class="card-cta">View project →</span>
  </div>
  <div class="card-right">
    <PortfolioBrowserFrame
      url={project.url}
      screenshot={project.screenshot}
      alt={`Screenshot of ${project.title}`}
    />
  </div>
</a>

<style>
  .portfolio-card {
    display: flex;
    flex-direction: row;
    min-height: 220px;
    background: #111820;
    border: 1px solid rgba(255, 140, 0, 0.15);
    border-left: 3px solid rgb(255, 140, 0);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .portfolio-card:hover,
  .portfolio-card:focus-visible {
    border-color: rgba(255, 140, 0, 0.5);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
    outline: none;
  }

  .card-left {
    flex: 0 0 40%;
    padding: 2rem 2rem 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-label {
    font-family: Consolas, Monaco, 'Andale Mono', 'Ubuntu Mono', monospace;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    color: rgb(255, 140, 0);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 1rem;
  }

  .label-line {
    display: inline-block;
    width: 16px;
    height: 1px;
    background: rgb(255, 140, 0);
    flex-shrink: 0;
  }

  .card-title {
    font-size: clamp(1.2rem, 2.5vw, 1.8rem);
    color: rgb(241, 241, 241);
    line-height: 1.2;
    margin-bottom: 0.3rem;
  }

  .card-tagline {
    font-family: Consolas, Monaco, 'Andale Mono', 'Ubuntu Mono', monospace;
    color: rgba(180, 190, 200, 0.7);
    font-size: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .card-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .pill {
    font-family: Consolas, Monaco, 'Andale Mono', 'Ubuntu Mono', monospace;
    font-size: 0.7rem;
    padding: 3px 10px;
    border-radius: 100px;
    border: 1px solid rgba(255, 140, 0, 0.3);
    background: rgba(255, 140, 0, 0.08);
    color: rgb(255, 140, 0);
  }

  .card-cta {
    color: rgb(255, 140, 0);
    font-size: 0.8rem;
    margin-top: 1rem;
  }

  .card-right {
    flex: 1;
    overflow: hidden;
    display: flex;
    align-items: stretch;
  }

  /* Override browser frame styles when inside a card */
  .card-right :global(.browser) {
    border-radius: 0;
    box-shadow: none;
    border: none;
    border-left: 1px solid rgba(255, 255, 255, 0.06);
    height: 100%;
  }

  .card-right :global(.browser-screen) {
    height: 100%;
  }

  @media (max-width: 599px) {
    .portfolio-card {
      flex-direction: column;
    }

    .card-left {
      flex: none;
      width: 100%;
      padding: 1.5rem;
    }

    .card-right {
      width: 100%;
      max-height: 240px;
    }

    .card-right :global(.browser-screen) {
      height: 240px;
    }
  }
</style>
