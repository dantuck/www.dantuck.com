---
export interface Props {
  project: {
    title: string;
    tagline: string;
    url: string;
    screenshot: string;
    techStack: string[];
    role: string;
    publishDate: string;
    bodyHtml: string;
  };
  index: number;
}

const { project, index } = Astro.props;
// Odd-indexed cards are wide (col-span-2, row-span-2): narrow, WIDE, narrow, WIDE, narrow
// gives the cleanest bento layout with minimal empty cells for 5 items in a 3-col grid
const wide = index % 2 === 1;
---

<div
  class:list={['portfolio-card', wide ? ['col-span-2', 'row-span-2'] : ['col-span-1', 'row-span-1']]}
  data-project={JSON.stringify(project)}
  role="button"
  tabindex="0"
  aria-label={`View details for ${project.title}`}
>
  <img src={project.screenshot} alt={`Screenshot of ${project.title}`} loading="lazy" />
  <div class="card-overlay">
    <strong class="card-title">{project.title}</strong>
    <span class="card-tagline">{project.tagline}</span>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.portfolio-card').forEach((card) => {
    const trigger = () => {
      const project = JSON.parse(card.dataset.project!);
      document.dispatchEvent(
        new CustomEvent('open-portfolio-drawer', { detail: project })
      );
    };
    card.addEventListener('click', trigger);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        trigger();
      }
    });
  });
</script>

<style>
  .portfolio-card {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    cursor: pointer;
    background: #1a2230;
    transition: border-color 0.15s ease;
  }

  .portfolio-card:hover,
  .portfolio-card:focus-visible {
    border-color: rgba(255, 140, 0, 0.5);
    outline: none;
  }

  .portfolio-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    margin: 0;
  }

  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.75rem 0.85rem 0.6rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.75));
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .card-title {
    color: rgb(255, 140, 0);
    font-size: 0.9rem;
    line-height: 1.2;
  }

  .card-tagline {
    color: rgba(200, 200, 200, 0.85);
    font-size: 0.75rem;
    line-height: 1.3;
  }
</style>
